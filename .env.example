# Config de Firebase (cliente). Copia este archivo a `.env` y rellena los valores.
# Se obtienen en: consola Firebase → ⚙ Configuración del proyecto → Tus apps →
# app web (</>) → objeto `firebaseConfig`.
# Estos valores son públicos (config de cliente); la seguridad la dan las rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ptem-a304f.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ptem-a304f
VITE_FIREBASE_STORAGE_BUCKET=ptem-a304f.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=944566588634
VITE_FIREBASE_APP_ID=
