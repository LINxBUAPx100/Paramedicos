{
  "name": "guia-de-lin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "La Guía de Lin — Guía de estudio avanzada de Atención Prehospitalaria, Cuidados Críticos y Transición a Medicina",
  "scripts": {
    "dev": "vite",
    "gen:nav": "node scripts/gen-nav-indice.mjs",
    "prebuild": "node scripts/gen-nav-indice.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test \"tests/*.test.mjs\"",
    "test:rules": "firebase emulators:exec --only firestore,storage --project ptem-rules-test \"node --test tests/rules/*.test.mjs\"",
    "gen:plantilla": "node scripts/gen-plantilla.mjs",
    "migrar": "node scripts/migrar-contenido.mjs",
    "replicar": "node scripts/replicar-contenido.mjs",
    "deploy": "npm run build"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@vitejs/plugin-react": "^4.3.1",
    "firebase-admin": "^14.1.0",
    "vite": "^5.4.8"
  }
}
