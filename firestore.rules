rules_version = '2';

// ============================================================
//  Security Rules — PTEM (auth + roles + progreso + panel)
// ------------------------------------------------------------
//  Modelo: academias/{codigo} · usuarios/{uid} · progreso/{uid} · intentos/{id}
//  Los roles viven en usuarios/{uid}.rol (sin custom claims todavía).
//  Jerarquía: superadmin (todo) > admin_escuela (su academia) >
//             instructor (ve su academia) > alumno.
//  El ADMIN SUPREMO se reconoce por su correo verificado de Auth
//  (no depende de su doc en Firestore), así nunca puede quedar fuera.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() { return request.auth != null; }
    function esDueno(uid) { return autenticado() && request.auth.uid == uid; }
    function miDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    // Admin supremo: reconocido por su correo de Auth (bootstrap sin consola).
    // El correo debe estar VERIFICADO: sin esto, cualquiera que registre una
    // cuenta con ese correo en otro proveedor podría suplantarlo.
    function esSupremo() {
      return autenticado()
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['mihayolo228@gmail.com'];
    }
    function esSuper() {
      return esSupremo()
        || (autenticado()
          && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
          && miDoc().rol == 'superadmin');
    }
    function academiaActiva(codigo) {
      return exists(/databases/$(database)/documents/academias/$(codigo))
        && get(/databases/$(database)/documents/academias/$(codigo)).data.estado == 'activo';
    }
    // ¿El solicitante es staff (instructor/maestro o admin de escuela) de esa academia?
    function esStaffDe(acaId) {
      return autenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (miDoc().rol == 'instructor' || miDoc().rol == 'admin_escuela')
        && miDoc().academiaId == acaId;
    }
    // ¿El solicitante es el director (admin de escuela) de esa academia?
    function esAdminDe(acaId) {
      return autenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && miDoc().rol == 'admin_escuela'
        && miDoc().academiaId == acaId;
    }
    // ¿El solicitante PERTENECE a esa academia (cualquier rol, alumno incluido)?
    function perteneceA(acaId) {
      return autenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && miDoc().academiaId == acaId;
    }
    // Plan EFECTIVO de una academia (espejo de src/lib/capacidades.js):
    // tipo 'avanzado' fuerza 'pro'; sin campo planComercial = 'pro' (academia
    // previa a los planes). Solo se evalúa en ESCRITURAS, nunca en lecturas.
    function academiaDoc(acaId) {
      return get(/databases/$(database)/documents/academias/$(acaId)).data;
    }
    function academiaPlanEfectivo(acaId) {
      return academiaDoc(acaId).get('tipo', 'basico') == 'avanzado'
        ? 'pro'
        : academiaDoc(acaId).get('planComercial', 'pro');
    }
    // ¿El plan permite editar contenido? (pro|curso). ¿Otorgar permisos
    // editoriales a profesores? (solo pro).
    function academiaEditaContenido(acaId) {
      return academiaPlanEfectivo(acaId) in ['pro', 'curso'];
    }
    function academiaOtorgaPermisos(acaId) {
      return academiaPlanEfectivo(acaId) == 'pro';
    }
    // Permisos editoriales del solicitante (usuarios/{uid}.permisosEditor); un
    // mapa que SOLO escribe el director PRO o el super-admin.
    function permEditor() { return miDoc().get('permisosEditor', {}); }
    function instructorPermite(clave) { return permEditor().get(clave, false) == true; }
    // Profesor con permisos editoriales sobre UN curso concreto. Sin
    // `editarContenido` + curso en `cursosPermitidos` no edita nada.
    function profesorPuedeEditar(acaId, cursoId) {
      return esStaffDe(acaId)
        && miDoc().rol == 'instructor'
        && instructorPermite('editarContenido')
        && cursoId in permEditor().get('cursosPermitidos', []);
    }
    // Rejilla FINA por campo para la escritura de un profesor: cada campo
    // sensible exige su permiso. `campo(clave)` = ese campo cambió en el diff.
    function cambia(clave) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([clave]);
    }
    function camposTemaSegunPermisos() {
      return (!cambia('quiz')        || instructorPermite('editarExamenes'))
        && (!cambia('actividades')   || instructorPermite('editarActividades'))
        && (!cambia('recursos')      || instructorPermite('administrarRecursos'))
        && (!cambia('estado')        || instructorPermite('publicarContenido'));
    }
    function cursoSegunPermisos() {
      return (!cambia('estado') || instructorPermite('publicarContenido'));
    }
    // Forma válida del mapa permisosEditor escrito por el director: solo las
    // 7 claves conocidas (6 booleanos + cursosPermitidos). Evita inyectar basura.
    function permisosEditorFormaValida() {
      return request.resource.data.permisosEditor is map
        && request.resource.data.permisosEditor.keys().hasOnly([
          'editarContenido', 'crearTemas', 'editarActividades', 'editarExamenes',
          'publicarContenido', 'administrarRecursos', 'cursosPermitidos']);
    }
    // Escritura de contenido por editores de academia (director/profesor):
    // - la versión sube EXACTAMENTE +1 (control de conflictos; nadie la
    //   reduce ni la manipula),
    // - los metadatos administrativos y de origen son intocables,
    // - el estado queda dentro del catálogo (borrador|publicado|archivado).
    // El super-admin no pasa por aquí (scripts de migración/clonación).
    function edicionContenidoValida() {
      return request.resource.data.get('version', 0) == resource.data.get('version', 0) + 1
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['academiaId', 'cursoId', 'temaId', 'plantillaId',
                      'plantillaOrigenId', 'versionOrigen', 'clonacion',
                      // 'origen' (sello de clonación/replicación, Fase 7) y
                      // 'replicacion' son huellas administrativas: si un editor
                      // pudiera tocarlas, ocultaría sus cambios a la replicación.
                      'origen', 'replicacion',
                      'creadoPor', 'creadoEn'])
        && request.resource.data.get('estado', 'borrador') in ['borrador', 'publicado', 'archivado'];
    }
    // Creación de contenido por editores de academia: firmada por su autor,
    // versión inicial 1 y estado del catálogo.
    function creacionContenidoValida() {
      return request.resource.data.get('creadoPor', null) == request.auth.uid
        && request.resource.data.get('version', 0) == 1
        && request.resource.data.get('estado', 'borrador') in ['borrador', 'publicado', 'archivado'];
    }
    // Canje de un código de prueba sobre el PROPIO perfil: el código debe
    // existir, estar activo y vigente, y pruebaHasta debe COPIAR su expiración
    // (nadie puede inventarse una fecha de prueba arbitraria).
    function codigoDoc(cod) {
      return get(/databases/$(database)/documents/codigos/$(cod)).data;
    }
    function canjeValido() {
      return ('codigoPrueba' in request.resource.data)
        && request.resource.data.codigoPrueba is string
        && exists(/databases/$(database)/documents/codigos/$(request.resource.data.codigoPrueba))
        && codigoDoc(request.resource.data.codigoPrueba).estado == 'activo'
        && codigoDoc(request.resource.data.codigoPrueba).expira > request.time
        && request.resource.data.pruebaHasta == codigoDoc(request.resource.data.codigoPrueba).expira;
    }
    // Unirse a un GRUPO por código (sobre el propio perfil): el grupo debe
    // existir, estar activo, y el academiaId nuevo debe ser LA academia del
    // grupo (unirse al grupo te une a su academia, que debe estar activa).
    function grupoDoc(cod) {
      return get(/databases/$(database)/documents/grupos/$(cod)).data;
    }
    function grupoValido() {
      return request.resource.data.grupoId is string
        && exists(/databases/$(database)/documents/grupos/$(request.resource.data.grupoId))
        && grupoDoc(request.resource.data.grupoId).estado == 'activo'
        && grupoDoc(request.resource.data.grupoId).academiaId == request.resource.data.academiaId
        && academiaActiva(request.resource.data.academiaId);
    }

    // --- ACADEMIAS (el id del doc ES el código, p.ej. "AEP-2026") ---
    match /academias/{codigo} {
      // Consultar UN código concreto: cualquier autenticado (validar el código
      // al unirse). NUNCA listar: si un usuario pudiera enumerar las academias
      // podría autoasignarse a cualquiera sin conocer su código de invitación.
      allow get: if autenticado();
      allow list: if esSuper();
      // Alta/edición/baja: solo super-admin.
      allow write: if esSuper();
      // El director puede editar SOLO la personalización de SU academia
      // (logo, lema, color del hero y — roadmap F7 — las SECCIONES del Home)
      // — nunca estado/plan/tipo/nombre — y SOLO si su plan comercial incluye
      // esa capacidad (pro|curso). Sin campo planComercial = academia previa
      // a los planes → se trata como 'pro' (mismo default que capacidades.js).
      // homeSecciones debe ser lista (o null = default); su contenido lo
      // normaliza homeModelo.js al leer (basura ⇒ default, nunca rompe).
      allow update: if esAdminDe(codigo)
        && resource.data.get('planComercial', 'pro') in ['pro', 'curso']
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['logo', 'lema', 'colorHero', 'homeSecciones'])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['homeSecciones'])
          || request.resource.data.homeSecciones == null
          || request.resource.data.homeSecciones is list
        );
    }

    // --- GRUPOS internos de una academia (el id del doc ES el código) ---
    match /grupos/{codigo} {
      // Consultar un código concreto: cualquier autenticado (para unirse).
      allow get: if autenticado();
      // Listar: super-admin o staff de esa academia.
      allow list: if esSuper() || esStaffDe(resource.data.academiaId);
      // Crear/renombrar/activar/borrar: super-admin o el DIRECTOR de esa
      // academia (los profesores no crean ni renombran grupos).
      allow create: if (esSuper() || esAdminDe(request.resource.data.academiaId))
        && request.resource.data.nombre is string
        && request.resource.data.estado == 'activo';
      allow update, delete: if esSuper() || esAdminDe(resource.data.academiaId);
      // Los PROFESORES de la academia pueden ajustar SOLO la visibilidad del
      // contenido para el grupo (qué fases/temas ven los alumnos).
      allow update: if esStaffDe(resource.data.academiaId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['fasesOcultas', 'temasOcultos']);
    }

    // --- REPORTES de problemas en temas (los revisa el super-admin) ---
    match /reportes/{id} {
      // Cualquier usuario autenticado reporta, firmando con su uid.
      allow create: if autenticado()
        && request.resource.data.uid == request.auth.uid;
      // Solo el super-admin los lee, resuelve o borra.
      allow read, update, delete: if esSuper();
    }

    // --- USUARIOS ---
    match /usuarios/{uid} {
      // El propio usuario, el super-admin, o el staff de su misma academia (para
      // que el maestro/admin vea a sus alumnos).
      allow read: if esDueno(uid) || esSuper() || esStaffDe(resource.data.academiaId);

      // Alta: solo tu propio doc, y siempre como 'alumno' (nadie se autonombra rol alto).
      allow create: if esDueno(uid)
        && request.resource.data.rol == 'alumno';

      // Edición propia: NO puedes cambiar tu rol ni tu estado; solo puedes fijar
      // academiaId a una academia que EXISTA y esté ACTIVA (unirse por código),
      // y tu acceso de prueba solo puede venir de un código VÁLIDO (canje).
      allow update: if esDueno(uid)
        // Los permisos editoriales NUNCA los edita el propio usuario (un
        // profesor no se auto-concede acceso): solo el director PRO / super.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['permisosEditor'])
        && request.resource.data.rol == resource.data.rol
        && request.resource.data.estado == resource.data.estado
        && (
          request.resource.data.academiaId == resource.data.academiaId
          || academiaActiva(request.resource.data.academiaId)
        )
        && (
          request.resource.data.get('pruebaHasta', null) == resource.data.get('pruebaHasta', null)
          || canjeValido()
        )
        && (
          request.resource.data.get('grupoId', null) == resource.data.get('grupoId', null)
          || request.resource.data.get('grupoId', null) == null
          || grupoValido()
        )
        // La marca de PRUEBA solo cambia con un canje válido o al unirse de
        // verdad (cambio de academia/grupo validado por las cláusulas de arriba).
        && (
          request.resource.data.get('esPrueba', false) == resource.data.get('esPrueba', false)
          || canjeValido()
          || request.resource.data.academiaId != resource.data.academiaId
          || request.resource.data.get('grupoId', null) != resource.data.get('grupoId', null)
        );

      // El director (admin_escuela) gestiona a los miembros de SU academia:
      // puede alternar alumno <-> instructor, activar/suspender, moverlos de
      // grupo y aprobar el acceso a códigos. Nunca a sí mismo, nunca a otro
      // admin/superadmin, no puede moverlos de academia, y NO puede tocar
      // ningún otro campo del perfil (affectedKeys lo acota técnicamente).
      allow update: if esAdminDe(resource.data.academiaId)
        && request.auth.uid != uid
        && resource.data.rol in ['alumno', 'instructor']
        && request.resource.data.rol in ['alumno', 'instructor']
        && request.resource.data.academiaId == resource.data.academiaId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rol', 'estado', 'grupoId', 'puedeVerCodigos'])
        // Si asigna grupo, debe ser un grupo de SU academia (o quitarlo).
        && (
          request.resource.data.get('grupoId', null) == resource.data.get('grupoId', null)
          || request.resource.data.get('grupoId', null) == null
          || (
            exists(/databases/$(database)/documents/grupos/$(request.resource.data.grupoId))
            && grupoDoc(request.resource.data.grupoId).academiaId == resource.data.academiaId
          )
        );

      // El DIRECTOR PRO concede/retira los PERMISOS EDITORIALES a los
      // PROFESORES de SU academia (Fase 6): SOLO el campo permisosEditor, con
      // forma válida, y solo si su plan otorga permisos editoriales (pro).
      // Nunca a sí mismo, nunca a un director/superadmin, nunca de otra
      // academia (esAdminDe fija la academia; rol == instructor fija el destino).
      allow update: if esAdminDe(resource.data.academiaId)
        && request.auth.uid != uid
        && resource.data.rol == 'instructor'
        && request.resource.data.rol == 'instructor'
        && academiaOtorgaPermisos(resource.data.academiaId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['permisosEditor'])
        && permisosEditorFormaValida();

      // El STAFF (profesor o director) puede HABILITAR módulos a los alumnos
      // de su academia: SOLO el campo fasesDesbloqueadas (anula lo oculto del
      // grupo para ese alumno, nada más).
      allow update: if esStaffDe(resource.data.academiaId)
        && resource.data.rol == 'alumno'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['fasesDesbloqueadas']);

      // Super-admin puede gestionar cualquier usuario (incluye al supremo
      // promoviendo su propio doc a rol 'superadmin' en su primer acceso).
      allow write: if esSuper();
    }

    // --- PROGRESO (privado por usuario; el super-admin puede limpiarlo al
    //     eliminar una cuenta) ---
    match /progreso/{uid} {
      allow read, write: if esDueno(uid);
      allow read, delete: if esSuper();
    }

    // --- CÓDIGOS de acceso temporal (prueba del servicio) ---
    match /codigos/{codigo} {
      // Canjear: cualquier autenticado puede CONSULTAR un código concreto.
      allow get: if autenticado();
      // Listarlos: el super-admin (todos) o el director (los de su academia).
      allow list: if esSuper() || esAdminDe(resource.data.academiaId);
      // Crear: super-admin, o director para SU academia. Siempre a futuro,
      // activo y firmado por quien lo crea.
      allow create: if (esSuper() || esAdminDe(request.resource.data.academiaId))
        && request.resource.data.creadoPor == request.auth.uid
        && request.resource.data.estado == 'activo'
        && request.resource.data.expira > request.time;
      // Desactivar/reactivar/borrar: super-admin o el director de su academia.
      allow update, delete: if esSuper() || esAdminDe(resource.data.academiaId);
    }

    // --- SOLICITUDES de acceso ---
    //  tipo 'modulo'  → alumno terminó una fase y pide la siguiente.
    //  tipo 'codigos' → profesor pide ver los códigos de academia/grupos.
    match /solicitudes/{id} {
      // Crear: el propio usuario, firmando con su uid, siempre 'pendiente'
      // y sobre SU academia (no puede sembrar solicitudes en otra).
      allow create: if autenticado()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente'
        && request.resource.data.academiaId == miDoc().academiaId;
      // Leer: el dueño (consulta el estado de las suyas), el super-admin o
      // el staff de esa academia (las atiende en su panel).
      allow read: if esDueno(resource.data.uid)
        || esSuper()
        || esStaffDe(resource.data.academiaId);
      // Resolver: módulo → cualquier staff de la academia; códigos → solo el
      // director o el super-admin (un profesor no se auto-aprueba: además,
      // puedeVerCodigos solo lo escribe el director/super en usuarios).
      allow update: if esSuper()
        || esAdminDe(resource.data.academiaId)
        || (esStaffDe(resource.data.academiaId) && resource.data.tipo == 'modulo');
      allow delete: if esSuper() || esAdminDe(resource.data.academiaId);
    }

    // --- INTENTOS de examen de fase ---
    match /intentos/{id} {
      // Crear: el propio alumno, con su uid y su academia (no puede falsear
      // otra) y con un RESULTADO consistente (Fase 4): nadie inventa un
      // porcentaje desde el cliente. Tolerancia de ±1 punto por el redondeo
      // (porcentaje = round(aciertos/total*100), como calcula la app).
      allow create: if autenticado()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.academiaId == miDoc().academiaId
        && request.resource.data.total is int
        && request.resource.data.total > 0
        && request.resource.data.total <= 500
        && request.resource.data.aciertos is int
        && request.resource.data.aciertos >= 0
        && request.resource.data.aciertos <= request.resource.data.total
        && request.resource.data.porcentaje is int
        && request.resource.data.porcentaje >= 0
        && request.resource.data.porcentaje <= 100
        && request.resource.data.porcentaje * request.resource.data.total
             >= request.resource.data.aciertos * 100 - request.resource.data.total
        && request.resource.data.porcentaje * request.resource.data.total
             <= request.resource.data.aciertos * 100 + request.resource.data.total;
      // Leer: el dueño, el super-admin, o el staff de la misma academia.
      allow read: if esDueno(resource.data.uid)
        || esSuper()
        || esStaffDe(resource.data.academiaId);
      // Inmutables para los usuarios; el super-admin puede editarlos (p. ej.
      // migrar academiaId al cambiar el código de una academia) o borrarlos.
      allow update, delete: if esSuper();
    }

    // --- CONFIGURACIÓN global de la plataforma (solo super-admin) ---
    //  p. ej. configuracion/anuncio = banner que ven todos los usuarios.
    match /configuracion/{doc} {
      allow read: if true;         // el anuncio se muestra a cualquiera
      allow write: if esSuper();   // solo el super-admin lo edita
    }

    // ================= CONTENIDO MULTIACADEMIA (Fase 2) =================
    //  Plantillas GLOBALES (catálogo) + copia INDEPENDIENTE por academia.
    //  Nunca dos academias escriben el mismo doc: las plantillas son de solo
    //  lectura para todos menos el super-admin, y cada academia opera su
    //  copia (docs con SU academiaId; el academiaId es INMUTABLE, así que
    //  cambiarlo desde el cliente no permite apropiarse de documentos).

    // --- PLANTILLAS globales (catálogo oficial): SOLO super-admin ---
    // Nadie más las LEE siquiera (un alumno/director no enumera el catálogo
    // privado). El CONTENIDO (estructura) de una plantilla PUBLICADA es
    // inmutable incluso para el super-admin: se abre la versión siguiente
    // (el update de metadatos/estado/version sí se permite).
    match /plantillas/{plantillaId} {
      allow read, create, delete: if esSuper();
      allow update: if esSuper()
        && (
          resource.data.get('estado', 'borrador') != 'publicada'
          || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['estructura'])
        );
    }
    match /plantillasTemas/{docId} {
      allow read, write: if esSuper();
    }

    // --- VERSIONES publicadas de plantillas (snapshots INMUTABLES, Fase 7) ---
    // Se crean al publicar y JAMÁS se actualizan (ni el super-admin): son el
    // origen exacto de clonaciones/replicaciones y la base del rollback.
    // Borrar versiones usadas por academias se bloquea en la capa de datos
    // (versionEstaEnUso); las reglas permiten depurar solo al super-admin.
    match /plantillasVersiones/{docId} {
      allow read, create, delete: if esSuper();
      allow update: if false;
    }
    match /plantillasVersionesTemas/{docId} {
      allow read, create, delete: if esSuper();
      allow update: if false;
    }

    // --- OPERACIONES de replicación (auditoría de dry-run/aplicación/rollback) ---
    // Solo el super-admin: las academias no leen ni modifican reportes.
    match /replicaciones/{id} {
      allow read, write: if esSuper();
    }

    // --- CURSOS por academia (estructura ligera del temario) ---
    match /cursos/{cursoId} {
      // Leer: super-admin; staff de la academia (incluye borradores);
      // alumnos de la academia SOLO lo publicado.
      allow get, list: if esSuper()
        || esStaffDe(resource.data.academiaId)
        || (perteneceA(resource.data.academiaId) && resource.data.estado == 'publicado');
      // Crear: super-admin, o el DIRECTOR de su academia si su plan permite
      // editar contenido (base NO edita). El doc nace con SU academiaId,
      // firmado por su autor y con versión 1 (Fase 3).
      allow create: if esSuper()
        || (esAdminDe(request.resource.data.academiaId)
            && academiaEditaContenido(request.resource.data.academiaId)
            && creacionContenidoValida());
      // Editar: mismo criterio + profesor con permiso sobre ESTE curso.
      // El academiaId es inmutable (nadie "adopta" cursos de otra academia)
      // y los editores no-super cumplen edicionContenidoValida (versión +1,
      // metadatos intocables, estado del catálogo). El profesor, además, solo
      // cambia el estado (publicar/archivar) con el permiso publicarContenido.
      allow update: if request.resource.data.academiaId == resource.data.academiaId
        && (
          esSuper()
          || (
            esAdminDe(resource.data.academiaId)
            && academiaEditaContenido(resource.data.academiaId)
            && edicionContenidoValida()
          )
          || (
            profesorPuedeEditar(resource.data.academiaId, cursoId)
            && edicionContenidoValida()
            && cursoSegunPermisos()
          )
        );
      // Sin eliminación destructiva por academias (archivar = update de estado).
      allow delete: if esSuper();
    }

    // --- TEMAS por academia (contenido pesado, 1 doc por tema) ---
    match /temas/{docId} {
      // Leer: super-admin; staff de la academia (incluye borradores);
      // alumnos de la academia SOLO temas publicados (los borradores no
      // se filtran a los alumnos ni de su propia academia).
      allow get, list: if esSuper()
        || esStaffDe(resource.data.academiaId)
        || (perteneceA(resource.data.academiaId) && resource.data.estado == 'publicado');
      // Crear: super; director PRO; o profesor con permiso de edición sobre el
      // curso Y el permiso crearTemas (crear un tema nuevo es "crear").
      allow create: if (esSuper()
          || (
            esAdminDe(request.resource.data.academiaId)
              && academiaEditaContenido(request.resource.data.academiaId)
              && creacionContenidoValida()
          )
          || (
            profesorPuedeEditar(request.resource.data.academiaId, request.resource.data.cursoId)
              && instructorPermite('crearTemas')
              && creacionContenidoValida()
          ))
        && request.resource.data.academiaId is string
        && request.resource.data.cursoId is string
        && request.resource.data.temaId is string;
      // academiaId, cursoId y temaId INMUTABLES: un tema no cambia de dueño
      // ni de curso desde el cliente (las llaves del progreso se preservan).
      // Los editores no-super cumplen además edicionContenidoValida; el
      // profesor, la rejilla FINA por campo (quiz/actividades/recursos/estado).
      allow update: if request.resource.data.academiaId == resource.data.academiaId
        && request.resource.data.cursoId == resource.data.cursoId
        && request.resource.data.temaId == resource.data.temaId
        && (
          esSuper()
          || (
            esAdminDe(resource.data.academiaId)
              && academiaEditaContenido(resource.data.academiaId)
              && edicionContenidoValida()
          )
          || (
            profesorPuedeEditar(resource.data.academiaId, resource.data.cursoId)
              && edicionContenidoValida()
              && camposTemaSegunPermisos()
          )
        );
      allow delete: if esSuper();
    }

    // --- HISTORIAL de cambios de contenido (auditoría append-only) ---
    match /historial/{id} {
      // Crear: staff de la academia o super-admin, firmando con su uid.
      allow create: if request.resource.data.usuario == request.auth.uid
        && (esSuper() || esStaffDe(request.resource.data.academiaId));
      // Leer: super-admin o el director de esa academia.
      allow read: if esSuper() || esAdminDe(resource.data.academiaId);
      // Append-only: nadie edita; solo el super-admin puede depurar.
      allow delete: if esSuper();
    }

    // --- RESPALDOS previos a sobrescrituras (los usa la replicación, Fase 9) ---
    match /respaldos/{id} {
      allow read, write: if esSuper();
    }
  }
}
